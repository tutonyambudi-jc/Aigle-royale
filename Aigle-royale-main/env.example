# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aigle_royale?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-with-a-long-random-secret"

# Cron secret: used to protect scheduled endpoints (set a strong value in production)
# En NODE_ENV=production, une valeur absente, trop courte (<16) ou "dev-secret" bloque l'endpoint cron.
CRON_SECRET="replace-with-a-strong-random-secret"

# Demo seeding control: set to 'true' to create demo accounts (only for local/dev)
# When enabled you can set `ADMIN_PASSWORD`, otherwise demo users are skipped.
DEMO_SEED="false"
ADMIN_PASSWORD=""

# Devise (affichage) - conversion FC -> USD
# Exemple: 1 USD ≈ 600 FC (ajustez selon votre taux)
NEXT_PUBLIC_USD_FC_RATE=600
NEXT_PUBLIC_WIFI_PASS_PRICE_FC=1000
NEXT_PUBLIC_EXTRA_BAGGAGE_PIECE_PRICE_FC=1000
NEXT_PUBLIC_EXTRA_BAGGAGE_OVERWEIGHT_PRICE_FC_PER_KG=200

# Payment Providers (optionnel)
MOBILE_MONEY_API_KEY=""
CARD_PAYMENT_API_KEY=""

# Support WhatsApp (optionnel — configurable aussi dans /admin/support/settings)
# Numéro en chiffres uniquement, indicatif pays (ex. 243…)
SUPPORT_WHATSAPP_NUMBER=""
SUPPORT_WHATSAPP_PREFILL=""

# Brevo (ex-Sendinblue) — emails / SMS transactionnels (optionnel)
# Sans ces variables, le module notifications reste en mode mock (logs console).
# Doc API : https://developers.brevo.com/
BREVO_API_KEY=""
# Email expéditeur vérifié dans Brevo
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME="Aigle Royale"
# SMS : expéditeur alphanumérique (souvent 3–11 caractères). Numéros destinataires en E.164 (+243…)
BREVO_SMS_SENDER=""

